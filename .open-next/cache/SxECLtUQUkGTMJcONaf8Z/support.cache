\"$\",\"p\",null,{\"className\":\"mb-3 text-xs font-medium uppercase text-white/40\",\"children\":\"Common Questions\"}],[\"$\",\"h2\",null,{\"id\":\"faq-heading\",\"className\":\"font-extrabold text-white leading-tight\",\"style\":{\"fontSize\":\"clamp(1.75rem, 3.5vw, 2.75rem)\"},\"children\":\"Frequently Asked Questions\"}]]}],[\"$\",\"$L11\",null,{\"type\":\"single\",\"collapsible\":true,\"className\":\"w-full space-y-2\",\"children\":[[\"$\",\"$L12\",\"0\",{\"value\":\"item-0\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$L13\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Wat maakt Keizer & De Kroon uniek?\"}],[\"$\",\"$L14\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Wij specialiseren ons in hoogwaardig schilderwerk in het hogere segment. Met een focus op uitstraling, detail en afwerking verzorgen wij werkzaamheden in karaktervol vastgoed in Amsterdam centrum. Onze zorgvuldige werkwijze zorgt voor minimale verstoring.\"}]]}],[\"$\",\"$L12\",\"1\",{\"value\":\"item-1\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$L13\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Hoe verloopt een project bij Keizer & De Kroon?\"}],[\"$\",\"$L14\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"We starten met een opname op locatie, maken vervolgens een inventarisatie en voorstel. Na akkoord bereiden we de werkzaamheden zorgvuldig voor, voeren het schilderwerk uit volgens planning, controleren het resultaat bij oplevering en blijven ook daarna bereikbaar voor nazorg.\"}]]}],[\"$\",\"$L12\",\"2\",{\"value\":\"item-2\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$L13\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Kan ik mijn pand in gebruik houden tijdens de werkzaamheden?\"}],[\"$\",\"$L14\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Ja, absoluut. Blijft uw pand in gebruik tijdens onze werkzaamheden? Dan stemmen wij onze werkwijze hier zorgvuldig op af, zodat processen en het dagelijks gebruik van het pand zo min mogelijk verstoord worden.\"}]]}],[\"$\",\"$L12\",\"3\",{\"value\":\"item-3\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$L13\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Waar zijn jullie actief?\"}],[\"$\",\"$L14\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Onze werkzaamheden vinden voornamelijk plaats in karaktervol commercieel en particulier vastgoed in het centrum van Amsterdam en directe omgeving.\"}]]}],[\"$\",\"$L12\",\"4\",{\"value\":\"item-4\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$L13\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Wat voor type panden behandelen jullie?\"}],[\"$\",\"$L14\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Wij verzorgen hoogwaardig binnenschilderwerk en vastgoedonderhoud voor panden waar uitstraling, detail en afwerking van belang zijn. Dit betreft zowel commercieel als particulier vastgoed.\"}]]}],[\"$\",\"$L12\",\"5\",{\"value\":\"item-5\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$L13\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Hoe neem ik contact op voor een offerte?\"}],\"$L15\"]}],\"$L16\",\"$L17\"]}]]}]}]\n9:[\"$\",\"section\"