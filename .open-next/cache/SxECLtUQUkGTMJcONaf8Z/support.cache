ite leading-tight\",\"style\":{\"fontSize\":\"clamp(1.75rem, 3.5vw, 2.75rem)\"},\"children\":\"Frequently Asked Questions\"}]]}],[\"$\",\"$Ld\",null,{\"type\":\"single\",\"collapsible\":true,\"className\":\"w-full space-y-2\",\"children\":[[\"$\",\"$Le\",\"0\",{\"value\":\"item-0\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$Lf\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Wat maakt Keizer & De Kroon uniek?\"}],[\"$\",\"$L10\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Wij specialiseren ons in hoogwaardig schilderwerk in het hogere segment. Met een focus op uitstraling, detail en afwerking verzorgen wij werkzaamheden in karaktervol vastgoed in Amsterdam centrum. Onze zorgvuldige werkwijze zorgt voor minimale verstoring.\"}]]}],[\"$\",\"$Le\",\"1\",{\"value\":\"item-1\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$Lf\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Hoe verloopt een project bij Keizer & De Kroon?\"}],[\"$\",\"$L10\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"We starten met een opname op locatie, maken vervolgens een inventarisatie en voorstel. Na akkoord bereiden we de werkzaamheden zorgvuldig voor, voeren het schilderwerk uit volgens planning, controleren het resultaat bij oplevering en blijven ook daarna bereikbaar voor nazorg.\"}]]}],[\"$\",\"$Le\",\"2\",{\"value\":\"item-2\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$Lf\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Kan ik mijn pand in gebruik houden tijdens de werkzaamheden?\"}],[\"$\",\"$L10\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Ja, absoluut. Blijft uw pand in gebruik tijdens onze werkzaamheden? Dan stemmen wij onze werkwijze hier zorgvuldig op af, zodat processen en het dagelijks gebruik van het pand zo min mogelijk verstoord worden.\"}]]}],[\"$\",\"$Le\",\"3\",{\"value\":\"item-3\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$Lf\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Waar zijn jullie actief?\"}],[\"$\",\"$L10\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Onze werkzaamheden vinden voornamelijk plaats in karaktervol commercieel en particulier vastgoed in het centrum van Amsterdam en directe omgeving.\"}]]}],[\"$\",\"$Le\",\"4\",{\"value\":\"item-4\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$Lf\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Wat voor type panden behandelen jullie?\"}],[\"$\",\"$L10\",null,{\"className\":\"text-white/60 leading-relaxed pb-5 text-sm\",\"children\":\"Wij verzorgen hoogwaardig binnenschilderwerk en vastgoedonderhoud voor panden waar uitstraling, detail en afwerking van belang zijn. Dit betreft zowel commercieel als particulier vastgoed.\"}]]}],[\"$\",\"$Le\",\"5\",{\"value\":\"item-5\",\"className\":\"border border-white/8 rounded-xl px-6 data-[state=open]:border-white/16\",\"children\":[[\"$\",\"$Lf\",null,{\"className\":\"text-left text-white font-medium hover:no-underline py-5 text-base\",\"children\":\"Hoe neem ik contact op voor een offerte?\"}],\"$L11\"]}],\"$L12\",\"$L13\"]}]]}]}]\n7:[\"$\",\"section\",null,{\"className\":\"gradient-brand py-20\",\"aria-label\":\"Contact CTA\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-[600px] px-6 text-center\",\"children\":[[\"$\",\"h2\",null,{\"className\"