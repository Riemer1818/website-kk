xt-sm uppercase tracking-wide\",\"children\":\"Chrome Web Store — Limited Use Disclosure\"}],[\"$\",\"p\",null,{\"className\":\"text-[#444] text-sm leading-relaxed\",\"children\":[\"The use and transfer to any other app of information received from Google APIs will adhere to the\",\" \",[\"$\",\"a\",null,{\"href\":\"https://developer.chrome.com/docs/webstore/program_policies/user_data_faq/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-[#ff656a] hover:text-[#fc0a7e] transition-colors\",\"children\":\"Chrome Web Store User Data Policy\"}],\", including the Limited Use requirements. BetterBooking.ai only accesses data you explicitly request it to access, uses that data solely to provide the negotiation service you initiated, and does not transfer, sell, or repurpose it for any other use.\"]}]]}],[\"$\",\"p\",null,{\"className\":\"text-lg text-[#444] leading-relaxed mb-12 border-l-4 border-[#ff656a] pl-5\",\"children\":\"BetterBooking.ai is committed to protecting your privacy. This policy explains what information our Chrome extension and website collect, how we use it, and your rights regarding your data.\"}],[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"1-what-betterbooking-does\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"1-what-betterbooking-does\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"1. What BetterBooking Does\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":\"BetterBooking.ai is a Chrome browser extension that helps you get lower prices on Airbnb listings using artificial intelligence. When you find a listing you like and click “Get BetterBooking”, our AI crafts and sends a polite negotiation message to the host on your behalf — helping you secure a better rate automatically.\"}],[\"$\",\"p\",null,{\"children\":\"By using BetterBooking, you expressly authorize us to send AI-generated negotiation messages to hosts each time you initiate a negotiation. You may review your full message history at any time within the extension.\"}]]}]]}],[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"2-chrome-extension-permissions\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"2-chrome-extension-permissions\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"2. Chrome Extension Permissions\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"BetterBooking requires read access to \",[\"$\",\"strong\",null,{\"children\":\"airbnb.com\"}],\" in order to retrieve listing information visible on the page — such as price, property details, and host information. This access is strictly:\"]}],\"$L3\"]}]]}],\"$L4\",\"$L5\",\"$L6\",\"$L7\",\"$L8\",\"$L9\",\"$La\",\"$Lb\",\"$Lc\",\"$Ld\",\"$Le\"]}]}]]}],\"$Lf\"],[\"$L10\",\"$L11\"],\"$L12\"]}],\"loading\":null,\"isPartial\":false}\n3:[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"User-initiated only:\"}],\" The extension reads page data exclusively when you click “Get BetterBooking.” It never passively monitors, scans, or transmits page content in the background without your direct action.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Narrowly scoped:\"}],\" Only data relevant to the specific listing you are actively viewing is accessed. We do not read unrelated pages, your browser history, inbox, or any personal messages outside the negotiation context.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Purpose-bound:\"}],\" Listing data is used exclusively to generate your negotiation message. It is never repurposed for advertising, profiling, or any secondary use.\"]}]]}]\n4:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"3-information-we-collect\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"3-information-we-collect\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"3. Information We Collect\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"Information you provide:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Email address (for account creation and service notifications)\"}],[\"$\",\"li\",null,{\"children\":\"Subscription and billing details (processed by Stripe — we never store your card number)\"}],[\"$\",\"li\",null,{\"children\":\"Your negotiation preferences (target price, reservation price) when you enter them\"}]]}],[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"Listing data read when you actively initiate a negotiation:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Property details: title, location, room type, amenities, description\"}],[\"$\",\"li\",null,{\"children\":\"Pricing: listed price, fees, discounts\"}],[\"$\",\"li\",null,{\"children\":\"Host information: name, response rate, rating, review count\"}],[\"$\",\"li\",null,{\"children\":\"Booking parameters: dates, number of guests\"}]]}],[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"Data generated through our service:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"AI-generated negotiation messages sent on your behalf\"}],[\"$\",\"li\",null,{\"children\":\"Conversation history between the negotiation agent and hosts\"}],[\"$\",\"li\",null,{\"children\":\"Negotiation status and outcomes\"}]]}],[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"Technical and usage data:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Timestamps of feature usage\"}],[\"$\",\"li\",null,{\"children\":\"Session and request identifiers (for debugging and support)\"}],[\"$\",\"li\",null,{\"children\":\"Aggregated, anonymized success metrics\"}]]}],[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"We do NOT collect:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Your passwords or login credentials\"}],[\"$\",\"li\",null,{\"children\":\"Authentication cookies or session tokens\"}],[\"$\",\"li\",null,{\"children\":\"Payment methods stored in your booking accounts\"}],[\"$\",\"li\",null,{\"children\":\"Personal messages unrelated to BetterBooking negotiations\"}],[\"$\",\"li\",null,{\"children\":\"Your browsing history outside of active Airbnb listing pages\"}],[\"$\",\"li\",null,{\"children\":\"Location data beyond what appears in listing details\"}]]}]]}]]}]\n5:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"4-how-the-negotiation-agent-works\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"4-how-the-negotiation-agent-works\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"4. How the Negotiation Agent Works\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"When you initiate a price negotiation, BetterBooking uses a\",\" \",[\"$\",\"strong\",null,{\"children\":\"user-authorized, ephemeral browser session\"}],\" managed through our Kernel infrastructure partner to deliver your AI-crafted message to the host. The following principles govern every session:\"]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Strictly user-initiated:\"}],\" The session activates only when you explicitly click “Get BetterBooking.” No action is taken passively, automatically, or without your direct instruction.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Credentials entered directly by you:\"}],\" Any credentials required to access the booking platform are entered by you directly into the platform's own native login interface. BetterBooking does not intercept, capture, store, or transmit those credentials at any point.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"No token or cookie harvesting:\"}],\" BetterBooking does not extract, retain, or transmit authentication cookies, session tokens, OAuth tokens, or any other credential artifacts. These remain solely within your browser session and are never accessible to our servers.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Ephemeral and self-terminating:\"}],\" Remote sessions automatically terminate upon task completion or after 15 minutes of inactivity. No session state, credential, or token is persisted after termination.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Authorized scope only:\"}],\" The agent performs exclusively the messaging action you requested — sending your negotiation message and returning the host's response. It takes no other action on your account.\"]}]]}],[\"$\",\"p\",null,{\"children\":\"This architecture ensures BetterBooking operates solely as your explicitly authorized agent, with no ability to access your accounts beyond the specific task you initiate.\"}]]}]]}]\n6:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"5-how-we-use-your-information\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"5-how-we-use-your-information\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"5. How We Use Your Information\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We use the information described above solely for the following purposes:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"To generate and send AI-powered negotiation messages on your behalf\"}],[\"$\",\"li\",null,{\"children\":\"To manage your BetterBooking account, subscription, and billing\"}],[\"$\",\"li\",null,{\"children\":\"To notify you when hosts respond to your negotiations\"}],[\"$\",\"li\",null,{\"children\":\"To provide customer support\"}],[\"$\",\"li\",null,{\"children\":\"To improve our AI and service quality using anonymized, aggregated data only\"}]]}],[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"We do NOT:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Sell your data to third parties, data brokers, or advertisers\"}],[\"$\",\"li\",null,{\"children\":\"Use your data for advertising, ad targeting, or behavioral profiling\"}],[\"$\",\"li\",null,{\"children\":\"Share your negotiation data with any unauthorized party\"}],[\"$\",\"li\",null,{\"children\":\"Make bookings or financial commitments on your behalf\"}],[\"$\",\"li\",null,{\"children\":\"Transfer user data for purposes inconsistent with this Privacy Policy\"}]]}]]}]]}]\n7:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"6-subprocessors-and-thirdparty-services\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"6-subprocessors-and-thirdparty-services\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"6. Subprocessors and Third-Party Services\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":\"We share limited, purpose-specific data with the following infrastructure providers. These are operational subprocessors — not data buyers or advertisers — and each is bound by a data processing agreement:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Supabase\"}],\" — Secure database hosting.\",\" \",[\"$\",\"em\",null,{\"children\":\"Receives:\"}],\" account information, listing data, conversation history. \",[\"$\",\"em\",null,{\"children\":\"Does not receive:\"}],\" payment information.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Anthropic (Claude API)\"}],\" — AI negotiation engine.\",\" \",[\"$\",\"em\",null,{\"children\":\"Receives:\"}],\" listing details and conversation context required to generate your message. \",[\"$\",\"em\",null,{\"children\":\"Does not receive:\"}],\" your email address or payment information.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Kernel\"}],\" — Ephemeral remote browser infrastructure.\",\" \",[\"$\",\"em\",null,{\"children\":\"Receives:\"}],\" listing URLs and negotiation task instructions.\",\" \",[\"$\",\"em\",null,{\"children\":\"Does not receive or store:\"}],\" credentials, authentication tokens, or personal account data of any kind.\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Stripe\"}],\" — Payment processing. \",[\"$\",\"em\",null,{\"children\":\"Receives:\"}],\" \",\"billing and subscription information. \",[\"$\",\"em\",null,{\"children\":\"Does not receive:\"}],\" \",\"negotiation data or listing information. Stripe processes payments as an independent data controller under its own privacy policy.\"]}]]}],[\"$\",\"p\",null,{\"children\":\"Optional diagnostic services (can be disabled on request):\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Langfuse\"}],\" — LLM performance monitoring, using anonymized, non-personal data only\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Grafana Loki\"}],\" — Error logging, using anonymized diagnostic data only\"]}]]}],[\"$\",\"p\",null,{\"children\":\"We do not sell, rent, or trade your personal information to any third party. No user data is shared with advertising networks or data brokers.\"}]]}]]}]\n8:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"7-data-security\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"7-data-security\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"7. Data Security\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"Technical measures:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"All data transmitted over HTTPS with TLS 1.3 encryption\"}],[\"$\",\"li\",null,{\"children\":\"Database-level encryption at rest\"}],[\"$\",\"li\",null,{\"children\":\"Row-level security preventing cross-user data access\"}],[\"$\",\"li\",null,{\"children\":\"Token-based authentication (JWT)\"}],[\"$\",\"li\",null,{\"children\":\"API rate limiting to prevent abuse\"}]]}],[\"$\",\"p\",null,{\"children\":[\"$\",\"strong\",null,{\"children\":\"Operational measures:\"}]}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Remote browser sessions expire after 15 minutes of inactivity and leave no stored state\"}],[\"$\",\"li\",null,{\"children\":\"No long-term storage of credentials or authentication tokens\"}],[\"$\",\"li\",null,{\"children\":\"Employee access to production data is logged, audited, and access-controlled\"}],[\"$\",\"li\",null,{\"children\":\"Quarterly security reviews of infrastructure and code\"}]]}],[\"$\",\"p\",null,{\"children\":\"In the event of a data breach likely to affect your rights or freedoms, we will notify affected users within 72 hours by email and report to relevant authorities as required by applicable law.\"}]]}]]}]\n9:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"8-data-retention\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"8-data-retention\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"8. Data Retention\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Active negotiations:\"}],\" Retained until resolved, cancelled, or you request deletion\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Account information:\"}],\" Retained for the duration of your account and deleted upon your verified request\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Remote browser sessions:\"}],\" Terminated immediately after task completion; no session data is retained\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Billing records:\"}],\" 7 years (legal and tax compliance, held by Stripe under its own retention policy)\"]}]]}],[\"$\",\"p\",null,{\"children\":\"Following account deletion, we may retain anonymized, aggregated data with no connection to you personally for service improvement purposes.\"}]]}]]}]\na:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"9-your-rights\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"9-your-rights\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"9. Your Rights\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":\"You may at any time:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Request access to the personal data we hold about you\"}],[\"$\",\"li\",null,{\"children\":\"Request correction of inaccurate or incomplete data\"}],[\"$\",\"li\",null,{\"children\":\"Request deletion of your account and associated data\"}],[\"$\",\"li\",null,{\"children\":\"Opt out of marketing emails at any time using the unsubscribe link in any email we send\"}]]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"EU / UK users (GDPR):\"}],\" You additionally have the right to data portability, the right to object to or restrict processing, and the right to lodge a complaint with your local data protection authority. We rely on Standard Contractual Clauses (SCCs) for transfers of personal data from the EU/UK to the United States.\"]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"California users (CCPA):\"}],\" You have the right to know what personal information we collect and how it is used, the right to request deletion, and the right to non-discrimination for exercising these rights. We do not sell personal information.\"]}],[\"$\",\"p\",null,{\"children\":[\"To exercise any of the above rights, contact us at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:info@keizerendekroon.nl\",\"className\":\"text-[#ff656a] hover:text-[#fc0a7e] transition-colors\",\"children\":\"info@keizerendekroon.nl\"}],\". We will respond within 30 days.\"]}]]}]]}]\nb:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"10-childrens-privacy\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"10-childrens-privacy\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"10. Children's Privacy\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[\"$\",\"p\",null,{\"children\":\"BetterBooking.ai is not directed at children under the age of 13. We do not knowingly collect personal information from children. If you believe a child has provided us with personal information, please contact us and we will delete it promptly.\"}]}]]}]\nc:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"11-changes-to-this-policy\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"11-changes-to-this-policy\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"11. Changes to This Policy\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[\"$\",\"p\",null,{\"children\":\"We may update this Privacy Policy from time to time. When we do, we will update the “Last updated” date at the top of this page. For material changes, we will notify active users and newsletter subscribers by email. We encourage you to review this policy periodically.\"}]}]]}]\nd:[\"$\",\"section\",null,{\"className\":\"mb-10\",\"aria-labelledby\":\"12-contact-us\",\"children\":[[\"$\",\"h2\",null,{\"id\":\"12-contact-us\",\"className\":\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\",\"style\":{\"fontSize\":\"1.125rem\"},\"children\":\"12. Contact Us\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_li]:text-[#444] [&_p]:text-[#444]\",\"children\":[[\"$\",\"p\",null,{\"children\":\"If you have any questions, concerns, or requests regarding this Privacy Policy or our data practices, please contact us at:\"}],[\"$\",\"div\",null,{\"className\":\"mt-4 rounded-xl border border-black/8 bg-[#f9f9f9] p-5\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-[#111]\",\"children\":\"BetterBooking.ai\"}],[\"$\",\"p\",null,{\"className\":\"text-sm mt-1\",\"children\":[\"Email:\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:info@keizerendekroon.nl\",\"className\":\"text-[#ff656a] hover:text-[#fc0a7e] transition-colors\",\"children\":\"info@keizerendekroon.nl\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm mt-1\",\"children\":[\"Website:\",\" \",[\"$\",\"a\",null,{\"href\":\"https://betterbooking.ai\",\"className\":\"text-[#ff656a] hover:text-[#fc0a7e] transition-colors\",\"children\":\"betterbooking.ai\"}]]}]]}]]}]]}]\ne:[\"$\",\"div\",null,{\"className\":\"mt-16 pt-8 border-t border-black/8\",\"children\":[\"$\",\"$L13\",null,{\"href\":\"/\",\"className\":\"text-sm text-[#6b6b6b] hover:text-[#ff656a] transition-colors duration-200\",\"children\":\"← Back to BetterBooking.ai\"}]}]\nf:[\"$\",\"footer\",null,{\"className\":\"bg-white border-t border-black/8\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-[1200px] px-6 py-12\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-col md:flex-row items-start md:items-center justify-between gap-8\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-col gap-3\",\"children\":[[\"$\",\"$L13\",null,{\"href\":\"/\",\"aria-label\":\"Keizer & De Kroon — home\",\"className\":\"flex items-center gap-3\",\"children\":[[\"$\",\"$L14\",null,{\"src\":\"/favicon.png\",\"alt\":\"\",\"width\":48,\"height\":48,\"className\":\"size-12\"}],[\"$\",\"span\",null,{\"className\":\"font-bold text-[#111] text-lg\",\"children\":\"Keizer & De Kroon\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-sm text-[#6b6b6b] max-w-[260px] leading-relaxed\",\"children\":\"Excellent in schilderwerken\"}]]}],false]}],[\"$\",\"div\",null,{\"className\":\"mt-10 pt-6 border-t border-black/8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xs text-[#6b6b6b]\",\"children\":[\"© \",2026,\" \",\"Keizer & De Kroon\",\". All rights reserved.\"]}],[\"$\",\"a\",null,{\"href\":\"mailto:info@keizerendekroon.nl\",\"className\":\"text-xs text-[#6b6b6