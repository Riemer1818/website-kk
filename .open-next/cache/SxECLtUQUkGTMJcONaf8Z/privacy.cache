ation received from Google APIs will adhere to the\\\",\\\" \\\",[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"https://developer.chrome.com/docs/webstore/program_policies/user_data_faq/\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"text-[#ff656a] hover:text-[#fc0a7e] transition-colors\\\",\\\"children\\\":\\\"Chrome Web Store User Data Policy\\\"}],\\\", including the Limited Use requirements. BetterBooking.ai only accesses data you explicitly request it to access, uses that data solely to provide the negotiation service you initiated, and does not transfer, sell, or repurpose it for any other use.\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-lg text-[#444] leading-relaxed mb-12 border-l-4 border-[#ff656a] pl-5\\\",\\\"children\\\":\\\"BetterBooking.ai is committed to protecting your privacy. This policy explains what information our Chrome extension and website collect, how we use it, and your rights regarding your data.\\\"}],\\\"$L6\\\",\\\"$L7\\\",\\\"$L8\\\",\\\"$L9\\\",\\\"$La\\\",\\\"$Lb\\\",\\\"$Lc\\\",\\\"$Ld\\\",\\\"$Le\\\",\\\"$Lf\\\",\\\"$L10\\\",\\\"$L11\\\",\\\"$L12\\\"]}]}]]}],\\\"$L13\\\"],[\\\"$L14\\\",\\\"$L15\\\"],\\\"$L16\\\"]}],{},null,false,false]},null,false,false]},null,false,false],\\\"$L17\\\",false]],\\\"m\\\":\\\"$undefined\\\",\\\"G\\\":[\\\"$18\\\",[]],\\\"S\\\":true}\\n\"])</script><script>self.__next_f.push([1,\"19:I[99352,[\\\"/_next/static/chunks/e13c50eb0f2505d3.js\\\",\\\"/_next/static/chunks/33074d3ff5d0cd2d.js\\\",\\\"/_next/static/chunks/46ba3280c034cabb.js\\\"],\\\"\\\"]\\n1a:I[1793,[\\\"/_next/static/chunks/e13c50eb0f2505d3.js\\\",\\\"/_next/static/chunks/33074d3ff5d0cd2d.js\\\",\\\"/_next/static/chunks/46ba3280c034cabb.js\\\"],\\\"Image\\\"]\\n1b:I[36345,[\\\"/_next/static/chunks/33074d3ff5d0cd2d.js\\\",\\\"/_next/static/chunks/c4d90098b4abc498.js\\\"],\\\"OutletBoundary\\\"]\\n1c:\\\"$Sreact.suspense\\\"\\n1e:I[36345,[\\\"/_next/static/chunks/33074d3ff5d0cd2