 applicable law.\\\"}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"d:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mb-10\\\",\\\"aria-labelledby\\\":\\\"8-data-retention\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"8-data-retention\\\",\\\"className\\\":\\\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\\\",\\\"style\\\":{\\\"fontSize\\\":\\\"1.125rem\\\"},\\\"children\\\":\\\"8. Data Retention\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4 [\\u0026_ul]:list-disc [\\u0026_ul]:pl-6 [\\u0026_ul]:space-y-2 [\\u0026_li]:text-[#444] [\\u0026_p]:text-[#444]\\\",\\\"children\\\":[[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Active negotiations:\\\"}],\\\" Retained until resolved, cancelled, or you request deletion\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Account information:\\\"}],\\\" Retained for the duration of your account and deleted upon your verified request\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Remote browser sessions:\\\"}],\\\" Terminated immediately after task completion; no session data is retained\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Billing records:\\\"}],\\\" 7 years (legal and tax compliance, held by Stripe under its own retention policy)\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Following account deletion, we may retain anonymized, aggregated data with no connection to you personally for service improvement purposes.\\\"}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"e:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mb-10\\\",\\\"aria-labelledby\\\":\\\"9-your-rights\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"9-your-rights\\\",\\\"className\\