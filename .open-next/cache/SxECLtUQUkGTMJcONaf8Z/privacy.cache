 [\\u0026_ul]:list-disc [\\u0026_ul]:pl-6 [\\u0026_ul]:space-y-2 [\\u0026_li]:text-[#444] [\\u0026_p]:text-[#444]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"BetterBooking requires read access to \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"airbnb.com\\\"}],\\\" in order to retrieve listing information visible on the page — such as price, property details, and host information. This access is strictly:\\\"]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"User-initiated only:\\\"}],\\\" The extension reads page data exclusively when you click “Get BetterBooking.” It never passively monitors, scans, or transmits page content in the background without your direct action.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Narrowly scoped:\\\"}],\\\" Only data relevant to the specific listing you are actively viewing is accessed. We do not read unrelated pages, your browser history, inbox, or any personal messages outside the negotiation context.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Purpose-bound:\\\"}],\\\" Listing data is used exclusively to generate your negotiation message. It is never repurposed for advertising, profiling, or any secondary use.\\\"]}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"8:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mb-10\\\",\\\"aria-labelledby\\\":\\\"3-information-we-collect\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"3-information-we-collect\\\",\\\"className\\\":\\\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\\\",\\\"style\\\":{\\\"fontSize\\\":\\\"1.125rem\\\"},\\\"children\\\":\\\"3. Information We Collect\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4 [\\u0026_ul]:list-disc [\\u0026_ul]:pl-6 [\\u0026_ul]:space-y-2 [\\u0026_li]:text-[#444] [\\u0026_p]:text-[#444]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Information you provide:\\\"}]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Email address (for account creation and service notifications)\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Subscription and billing details (processed by Stripe — we never store your card number)\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Your negotiation preferences (target price, reservation price) when you enter them\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Listing data read when you actively initiate a negotiation:\\\"}]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Property details: title, location, room type, amenities, description\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Pricing: listed price, fees, discounts\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Host information: name, response rate, rating, review count\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Booking parameters: dates, number of guests\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Data generated through our service:\\\"}]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"AI-generated negotiation messages sent on your behalf\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Conversation history between the negotiation agent and hosts\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Negotiation status and outcomes\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Technical and usage data:\\\"}]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Timestamps of feature usage\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Session and request identifiers (for debugging and support)\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Aggregated, anonymized success metrics\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"We do NOT collect:\\\"}]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Your passwords or login credentials\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Authentication cookies or session tokens\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Payment methods stored in your booking accounts\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Personal messages unrelated to BetterBooking negotiations\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Your browsing history outside of active Airbnb listing pages\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Location data beyond what appears in listing details\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"9:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mb-10\\\",\\\"aria-labelledby\\\":\\\"4-how-the-negotiation-agent-works\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"4-how-the-negotiation-agent-works\\\",\\\"className\\\":\\\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\\\",\\\"style\\\":{\\\"fontSize\\\":\\\"1.125rem\\\"},\\\"children\\\":\\\"4. How the Negotiation Agent Works\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4 [\\u0026_ul]:list-disc [\\u0026_ul]:pl-6 [\\u0026_ul]:space-y-2 [\\u0026_li]:text-[#444] [\\u0026_p]:text-[#444]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"When you initiate a price negotiation, BetterBooking uses a\\\",\\\" \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"user-authorized, ephemeral browser session\\\"}],\\\" managed through our Kernel infrastructure partner to deliver your AI-crafted message to the host. The following principles govern every session:\\\"]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Strictly user-initiated:\\\"}],\\\" The session activates only when you explicitly click “Get BetterBooking.” No action is taken passively, automatically, or without your direct instruction.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Credentials entered directly by you:\\\"}],\\\" Any credentials required to access the booking platform are entered by you directly into the platform's own native login interface. BetterBooking does not intercept, capture, store, or transmit those credentials at any point.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"No token or cookie harvesting:\\\"}],\\\" BetterBooking does not extract, retain, or transmit authentication cookies, session tokens, OAuth tokens, or any other credential artifacts. These remain solely within your browser session and are never accessible to our servers.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Ephemeral and self-terminating:\\\"}],\\\" Remote sessions automatically terminate upon task completion or after 15 minutes of inactivity. No session state, credential, or token is persisted after termination.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Authorized scope only:\\\"}],\\\" The agent performs exclusively the messaging action you requested — sending your negotiation message and returning the host's response. It takes no other action on your account.\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"This architecture ensures BetterBooking operates solely as your explicitly authorized agent, with no ability to access your accounts beyond the specific task you initiate.\\\"}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"a:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mb-10\\\",\\\"aria-labelledby\\\":\\\"5-how-we-use-your-information\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"5-how-we-use-your-information\\\",\\\"className\\\":\\\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\\\",\\\"style\\\":{\\\"fontSize\\\":\\\"1.125rem\\\"},\\\"children\\\":\\\"5. How We Use Your Information\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4 [\\u0026_ul]:list-disc [\\u0026_ul]:pl-6 [\\u0026_ul]:space-y-2 [\\u0026_li]:text-[#444] [\\u0026_p]:text-[#444]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"We use the information described above solely for the following purposes:\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"To generate and send AI-powered negotiation messages on your behalf\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"To manage your BetterBooking account, subscription, and billing\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"To notify you when hosts respond to your negotiations\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"To provide customer support\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"To improve our AI and service quality using anonymized, aggregated data only\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"We do NOT:\\\"}]}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Sell your data to third parties, data brokers, or advertisers\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Use your data for advertising, ad targeting, or behavioral profiling\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Share your negotiation data with any unauthorized party\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Make bookings or financial commitments on your behalf\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"Transfer user data for purposes inconsistent with this Privacy Policy\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"b:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mb-10\\\",\\\"aria-labelledby\\\":\\\"6-subprocessors-and-thirdparty-services\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"id\\\":\\\"6-subprocessors-and-thirdparty-services\\\",\\\"className\\\":\\\"font-bold text-[#111] mb-4 pb-2 border-b border-black/8\\\",\\\"style\\\":{\\\"fontSize\\\":\\\"1.125rem\\\"},\\\"children\\\":\\\"6. Subprocessors and Third-Party Services\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4 [\\u0026_ul]:list-disc [\\u0026_ul]:pl-6 [\\u0026_ul]:space-y-2 [\\u0026_li]:text-[#444] [\\u0026_p]:text-[#444]\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"We share limited, purpose-specific data with the following infrastructure providers. These are operational subprocessors — not data buyers or advertisers — and each is bound by a data processing agreement:\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Supabase\\\"}],\\\" — Secure database hosting.\\\",\\\" \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Receives:\\\"}],\\\" account information, listing data, conversation history. \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Does not receive:\\\"}],\\\" payment information.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Anthropic (Claude API)\\\"}],\\\" — AI negotiation engine.\\\",\\\" \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Receives:\\\"}],\\\" listing details and conversation context required to generate your message. \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Does not receive:\\\"}],\\\" your email address or payment information.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Kernel\\\"}],\\\" — Ephemeral remote browser infrastructure.\\\",\\\" \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Receives:\\\"}],\\\" listing URLs and negotiation task instructions.\\\",\\\" \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Does not receive or store:\\\"}],\\\" credentials, authentication tokens, or personal account data of any kind.\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Stripe\\\"}],\\\" — Payment processing. \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Receives:\\\"}],\\\" \\\",\\\"billing and subscription information. \\\",[\\\"$\\\",\\\"em\\\",null,{\\\"children\\\":\\\"Does not receive:\\\"}],\\\" \\\",\\\"negotiation data or listing information. Stripe processes payments as an independent data controller under its own privacy policy.\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"Optional diagnostic services (can be disabled on request):\\\"}],[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Langfuse\\\"}],\\\" — LLM performance monitoring, using anonymized, non-personal data only\\\"]}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"Grafana Loki\\\"}],\\\" — Error logging, using anonymized diagnostic data only\\\"]}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"We do not sell, rent, or trade your personal information to any third party. No user data is shared with advertising networks or data brokers.\\\"}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"c:[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mb-10\\\",\\\"aria-labelledby\\\":\\\"7-data-security\\\",\\\"children\