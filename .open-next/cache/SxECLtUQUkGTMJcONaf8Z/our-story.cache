{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/our-story/layout,_N_T_/our-story/page,_N_T_/our-story"},"segmentPaths":["/_tree","/_full","/our-story/__PAGE__","/our-story","/_index","/_head"]},"html":"<!DOCTYPE html><!--SxECLtUQUkGTMJcONaf8Z--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Ffavicon.png&amp;w=48&amp;q=75 1x, /_next/image?url=%2Ffavicon.png&amp;w=96&amp;q=75 2x\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/6957cfeb8b74ae10.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/98df2cc20320078e.js\"/><script src=\"/_next/static/chunks/5faeea72d2e78ff5.js\" async=\"\"></script><script src=\"/_next/static/chunks/4911410e5153f0d7.js\" async=\"\"></script><script src=\"/_next/static/chunks/205289c74948131f.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-a9a24362ca441a03.js\" async=\"\"></script><script src=\"/_next/static/chunks/33074d3ff5d0cd2d.js\" async=\"\"></script><script src=\"/_next/static/chunks/c4d90098b4abc498.js\" async=\"\"></script><script src=\"/_next/static/chunks/e13c50eb0f2505d3.js\" async=\"\"></script><script src=\"/_next/static/chunks/46ba3280c034cabb.js\" async=\"\"></script><title>Our Story | Keizer &amp; De Kroon</title><meta name=\"description\" content=\"We built BetterBooking.ai to fight back against travel industry algorithms that charge you the maximum you&#x27;ll pay. Here&#x27;s why.\"/><meta property=\"og:title\" content=\"Keizer &amp; De Kroon — Excellent in schilderwerken\"/><meta property=\"og:description\" content=\"Vernieuwend en duurzaam vakmanschap, met focus op schilderwerk in het hogere segment in Amsterdam en omgeving.\"/><meta property=\"og:url\" content=\"https://www.keizerendekroon.nl\"/><meta property=\"og:site_name\" content=\"Keizer &amp; De Kroon\"/><meta property=\"og:locale\" content=\"nl_NL\"/><meta property=\"og:image\" content=\"https://www.keizerendekroon.nl/static/square_logo.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"1200\"/><meta property=\"og:image:alt\" content=\"Keizer &amp; De Kroon\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Keizer &amp; De Kroon — Excellent in schilderwerken\"/><meta name=\"twitter:description\" content=\"Vernieuwend en duurzaam vakmanschap, met focus op schilderwerk in het hogere segment in Amsterdam en omgeving.\"/><meta name=\"twitter:image\" content=\"https://www.keizerendekroon.nl/static/square_logo.png\"/><meta name=\"twitter:image:width\" content=\"1200\"/><meta name=\"twitter:image:height\" content=\"1200\"/><meta name=\"twitter:image:alt\" content=\"Keizer &amp; De Kroon\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0b3bf435.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/icon.jpg?icon.d5a99958.jpg\" sizes=\"150x128\" type=\"image/jpeg\"/><script src=\"/_next/static/chunks/a6dad97d9634a72d.js\" noModule=\"\"></script></head><body class=\"antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><nav class=\"fixed top-0 left-0 right-0 z-50 bg-white border-b border-black/8\" role=\"navigation\" aria-label=\"Main navigation\"><div class=\"mx-auto max-w-[1200px] px-6 flex items-center justify-between h-20\"><a aria-label=\"Keizer &amp; De Kroon — home\" class=\"flex items-center\" href=\"/\"><img alt=\"Keizer &amp; De Kroon\" width=\"48\" height=\"48\" decoding=\"async\" data-nimg=\"1\" class=\"size-12\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Ffavicon.png&amp;w=48&amp;q=75 1x, /_next/image?url=%2Ffavicon.png&amp;w=96&amp;q=75 2x\" src=\"/_next/image?url=%2Ffavicon.png&amp;w=96&amp;q=75\"/></a><div class=\"hidden md:flex items-center gap-8\"><a href=\"#features\" class=\"text-sm font-medium text-[#6b6b6b] hover:text-[#111] transition-colors duration-200 relative group\">Diensten<span class=\"absolute -bottom-0.5 left-0 w-full h-px bg-[#c44b2a] origin-left scale-x-0 transition-transform duration-200 group-hover:scale-x-100\"></span></a><a href=\"/contact\" class=\"text-sm font-medium text-[#6b6b6b] hover:text-[#111] transition-colors duration-200 relative group\">Contact<span class=\"absolute -bottom-0.5 left-0 w-full h-px bg-[#c44b2a] origin-left scale-x-0 transition-transform duration-200 group-hover:scale-x-100\"></span></a></div><button class=\"md:hidden p-3 text-[#111] hover:text-[#c44b2a]\" aria-expanded=\"false\" aria-controls=\"mobile-menu\" aria-label=\"Open menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></nav><main id=\"main-content\"><div class=\"gradient-hero pt-32 pb-20 md:pt-40 md:pb-24\"><div class=\"mx-auto max-w-[800px] px-6\"><p class=\"mb-4 text-xs font-medium uppercase text-white/50\">About Us</p><h1 class=\"font-extrabold text-white leading-tight\" style=\"font-size:clamp(2.5rem, 6vw, 4.5rem)\">Our Story</h1></div></div><div class=\"bg-[#111111]\"><div class=\"mx-auto max-w-[800px] px-6 py-20 md:py-28\"><p class=\"text-white/60 leading-relaxed mb-10\" style=\"font-size:clamp(1.05rem, 2vw, 1.2rem)\">Here is the secret the travel industry doesn&#x27;t want you to know: they are using massive amounts of data and technology to charge you as much as they possibly can. Whether it&#x27;s for a flight, a hotel, or a taxi, they use algorithms to figure out the absolute highest price you are willing to pay and then they try to charge you exactly that.</p><p class=\"font-extrabold text-white leading-tight mb-10\" style=\"font-size:clamp(2rem, 5vw, 3.25rem)\">We think it&#x27;s time to fight back.</p><p class=\"text-white/60 leading-relaxed\" style=\"font-size:clamp(1.05rem, 2vw, 1.2rem)\">We built BetterBooking.ai to put the power back in your hands. We&#x27;re making it as simple as possible for you to leverage the exact same AI and tech they use to maximize their profits, but with one massive difference: we are using it to save you money. Right now, our smart assistant is laser-focused on getting you a better deal on your Airbnb. There is no tech jargon to learn and no complicated setup. Just use it right alongside how you would ordinarily book an Airbnb, and we are incredibly confident we can lower your price. Give it a try.</p><div class=\"my-14 h-px bg-white/10\" aria-hidden=\"true\"></div><h2 class=\"mb-5 text-xs font-medium uppercase text-[#ff656a]\">Who are we?</h2><p class=\"text-white/60 leading-relaxed mb-8\" style=\"font-size:clamp(1.05rem, 2vw, 1.2rem)\">We are digital nomads who built this for people who love to travel. Why? We know how expensive and stressful traveling can be, and we want to make it easier and cheaper for you. We want you to use the money you save to extend your trip a few extra nights, explore a little further, have more experiences, benefit local economies, and ultimately see more of the world.</p><p class=\"text-white/50 text-sm mb-14\">Made with love. ❤️</p><div class=\"h-px bg-white/10 mb-14\" aria-hidden=\"true\"></div><div class=\"flex flex-wrap items-center gap-4\"><a href=\"#contact\" class=\"inline-flex items-center gap-2 rounded-full bg-[#ff656a] px-7 py-3.5 text-sm font-semibold text-white transition-colors duration-200 hover:bg-[#fc0a7e]\" target=\"_blank\" rel=\"noopener noreferrer\">Add to Chrome — It&#x27;s Free</a><a class=\"text-sm font-medium text-white/40 hover:text-white/80 transition-colors duration-200\" href=\"/\">← Back to home</a></div></div></div></main><footer class=\"bg-white border-t border-black/8\"><div class=\"mx-auto max-w-[1200px] px-6 py-12\"><div class=\"flex flex-col md:flex-row items-start md:items-center justify-between gap-8\"><div class=\"flex flex-col gap-3\"><a aria-label=\"Keizer &amp; De Kroon — home\" class=\"flex items-center gap-3\" href=\"/\"><img alt=\"\" loading=\"lazy\" width=\"48\" height=\"48\" decoding=\"async\" data-nimg=\"1\" class=\"size-12\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Ffavicon.png&amp;w=48&amp;q=75 1x, /_next/image?url=%2Ffavicon.png&amp;w=96&amp;q=75 2x\" src=\"/_next/image?url=%2Ffavicon.png&amp;w=96&amp;q=75\"/><span class=\"font-bold text-[#111] text-lg\">Keizer &amp; De Kroon</span></a><p class=\"text-sm text-[#6b6b6b] max-w-[260px] leading-relaxed\">Excellent in schilderwerken</p></div></div><div class=\"mt-10 pt-6 border-t border-black/8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4\"><p class=\"text-xs text-[#6b6b6b]\">© <!-- -->2026<!-- --> <!-- -->Keizer &amp; De Kroon<!-- -->. All rights reserved.</p><a href=\"mailto:info@keizerendekroon.nl\" class=\"text-xs text-[#6b6b6b] hover:text-[#111] transition-colors duration-200\">info@keizerendekroon.nl</a></div></div></footer><!--$--><!--/$--><section aria-label=\"Notifications alt+T\" tabindex=\"-1\" aria-live=\"polite\" aria-relevant=\"additions text\" aria-atomic=\"false\"></section><script src=\"/_next/static/chunks/98df2cc20320078e.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[3097,[\\\"/_next/static/chunks/33074d3ff5d0cd2d.js\\\",\\\"/_next/static/chunks/c4d90098b4abc498.js\\\"],\\\"default\\\"]\\n3:I[99299,[\\\"/_next/static/chunks/33074d3ff5d0cd2d.js\\\",\\\"/_next/static/chunks/c4d90098b4abc498.js\\\"],\\\"default\\\"]\\n4:I[13354,[\\\"/_next/static/chunks/e13c50eb0f2505d3.js\\\"],\\\"Toaster\\\"]\\n5:I[66250,[\\\"/_next/static/chunks/e13c50eb0f2505d3.js\\\"